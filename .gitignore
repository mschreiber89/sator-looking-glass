# dependencies
node_modules/
.pnpm-store/

# rust / anchor build artifacts (root-only — must not match
# Next.js route segments named "target")
/target/
.anchor/
**/*.rs.bk
test-ledger/

# next.js
.next/
out/

# build output
dist/
build/

# env
.env
.env.*
!.env.example

# editor / OS
.DS_Store
.idea/
.vscode/
.claude/
*.swp
*.swo

# logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*

# Anchor-generated keys we do not want committed
**/target/deploy/*-keypair.json
web/.next/
web/tsconfig.tsbuildinfo

# Any stray keypair JSON anywhere in the tree (defense in depth — never
# commit these by accident)
**/*-keypair.json
keeper-keypair.json
oracle-keypair.json
