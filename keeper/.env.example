# Solana RPC endpoint the keeper should talk to.
# Localnet: http://127.0.0.1:8899   Devnet: https://api.devnet.solana.com
RPC_URL=http://127.0.0.1:8899

# WebSocket endpoint for log subscriptions (event listener).
# Localnet: ws://127.0.0.1:8900    Devnet: wss://api.devnet.solana.com
WS_URL=ws://127.0.0.1:8900

# Path to the keypair that pays for tick transactions and rent.
KEEPER_KEYPAIR_PATH=/Users/you/.config/solana/id.json

# Path to the keypair that signs submit_prophecy. In Phase 3 this can
# safely be the same file as KEEPER_KEYPAIR_PATH; Phase 4 separates them.
ORACLE_KEYPAIR_PATH=/Users/you/.config/solana/id.json

# How often (ms) the tick scheduler wakes up to check whether to fire.
# 30000 (twice per minute) is a reasonable default for a 180s on-chain interval.
TICK_INTERVAL_MS=30000

# The deployed program ID.
PROGRAM_ID=GTEVyfq7zL91k1zjZrJCmkeidBvgDfMdEXUUsMcQWq5r

# Optional debug flag. If set to 1, the keeper attempts to fire a tick on
# every scheduler iteration regardless of the local 180s gate. The on-chain
# program will still reject early ticks with TickTooSoon, so this is purely
# a way to exercise the keeper-side flow during development. Leave blank for
# normal operation.
DEBUG_FAST_TICK=
